{
  "name": "hpc-ultra-platform",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "dev": "pnpm --parallel --filter @hpc-ultra/api --filter @hpc-ultra/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @hpc-ultra/db prisma:generate",
    "db:migrate": "pnpm --filter @hpc-ultra/db prisma:migrate"
  }
}
